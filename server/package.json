{
  "name": "roomdisplay-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc && mkdir -p dist/server/src/db && cp -r src/db/migrations dist/server/src/db/migrations",
    "start": "node dist/server/src/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "init-admin": "tsx src/scripts/init-admin.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/csrf-protection": "^6.4.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/session": "^10.9.0",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^8.3.1",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "kysely": "^0.28.2",
    "node-ical": "^0.20.1",
    "pino": "^8.21.0",
    "pino-pretty": "^10.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.12.7",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  }
}
