# ── Required ──────────────────────────────────────────────────────────────────

# 'production' | 'development'
NODE_ENV=development

# Port the HTTP server listens on. Use 80 in production (requires CAP_NET_BIND_SERVICE).
PORT=3000

# Directory for SQLite DB, uploaded images, backups, and cached data.
# In production: /var/lib/roomdisplay
DATA_DIR=./data

# SQLite database path (typically inside DATA_DIR).
DATABASE_URL=file:./data/app.db

# Used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-32-random-hex-bytes

# Used to encrypt stored calendar credentials (PCO tokens, iCal URLs).
# LOSING THIS MEANS RE-ENTERING ALL CALENDAR SOURCES.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-me-with-32-random-hex-bytes

# ── Optional ──────────────────────────────────────────────────────────────────

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Default time zone for new rooms (IANA format). Can be overridden per room.
DEFAULT_TIMEZONE=America/Chicago
